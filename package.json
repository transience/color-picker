{
  "name": "@transience/color-picker",
  "version": "0.2.1",
  "description": "A modern color picker component with support for OKLCH color space.",
  "author": "Gil Barbara <gilbarbara@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/transience/color-picker.git"
  },
  "bugs": {
    "url": "https://github.com/transience/color-picker/issues"
  },
  "homepage": "https://transience.github.io/color-picker/",
  "keywords": [
    "color-picker",
    "color",
    "picker",
    "react",
    "oklch"
  ],
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "license": "MIT",
  "peerDependencies": {
    "react": "16.8 - 19",
    "react-dom": "16.8 - 19",
    "tailwindcss": "3.4 - 4"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "colorizr": "^5.0.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@gilbarbara/eslint-config": "^1.2.1",
    "@gilbarbara/prettier-config": "^1.0.0",
    "@gilbarbara/tsconfig": "^1.0.0",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@storybook/addon-a11y": "^10.3.6",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/addon-vitest": "^10.3.6",
    "@storybook/react-vite": "^10.3.6",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "del-cli": "^7.0.0",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "jest-extended": "^7.0.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "repo-tools": "^0.3.1",
    "size-limit": "^12.1.0",
    "storybook": "^10.3.6",
    "tailwindcss": "^4.2.4",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "scripts": {
    "build": "npm run clean && tsup",
    "watch": "tsup --watch",
    "clean": "del dist/*",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch",
    "lint": "eslint --fix .",
    "typecheck": "tsc && tsc -p tests/tsconfig.json && tsc -p stories/tsconfig.json",
    "typevalidation": "attw -P",
    "format": "prettier \"**/*.{css,graphql,js,json,jsx,less,md,mdx,scss,ts,tsx,yaml,yml}\" --write",
    "size": "size-limit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "validate": "npm run lint && npm run typecheck && npm run test:coverage && npm run build && npm run size && npm run typevalidation",
    "prepare": "husky"
  },
  "tsup": {
    "bundle": true,
    "dts": true,
    "entry": [
      "src/index.ts"
    ],
    "format": [
      "cjs",
      "esm"
    ],
    "loader": {
      ".gif": "dataurl"
    },
    "sourcemap": true,
    "splitting": false
  },
  "prettier": "@gilbarbara/prettier-config",
  "size-limit": [
    {
      "name": "commonjs",
      "path": "./dist/index.cjs",
      "limit": "35 kB"
    },
    {
      "name": "esm",
      "path": "./dist/index.js",
      "limit": "30 kB"
    }
  ]
}
